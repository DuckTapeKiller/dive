{
  "version": 1,
  "databasePath": "~/dive/library.sqlite",
  "sources": [
    {
      "name": "Books",
      "type": "book",
      "path": "~/Libros",
      "extensions": [".epub"]
    },
    {
      "name": "Obsidian",
      "type": "note",
      "path": "",
      "extensions": [".md", ".txt"]
    }
  ],
  "chunking": {
    "targetChars": 2400,
    "overlapChars": 0,
    "minChars": 300,
    "maxChars": 3200
  },
  "search": {
    "keywordEnabled": false,
    "defaultLimit": 5,
    "maxLimit": 50,
    "maxContextChars": 12000,
    "rrfK": 60,
    "semanticWeight": 1,
    "keywordWeight": 1.1,
    "metadataWeight": 0.8,
    "sourceWeight": 1.2,
    "contentKeywordBonus": 0.16,
    "metadataKeywordBonus": 0.06,
    "maxPassagesPerSource": 5
  },
  "searchModes": {},
  "embedding": {
    "enabled": false,
    "model": "nomic-embed-text-v2-moe:latest",
    "dimensions": 0,
    "quantization": "int8",
    "ollamaBaseUrl": "http://127.0.0.1:11434",
    "batchSize": 16,
    "sqliteVecExtensionPath": ""
  },
  "chatIntegration": {
    "enabled": false,
    "limit": 20,
    "maxContextChars": 30000,
    "includeSourcePaths": true
  },
  "chatModes": {
    "ollama": { "enabled": false },
    "pi": { "enabled": false },
    "cloud": { "enabled": false }
  },
  "watch": {
    "enabled": false,
    "debounceMs": 2000,
    "rescanIntervalMs": 60000
  }
}
